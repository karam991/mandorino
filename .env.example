# Mandorino — Umgebungsvariablen
# Kopiere diese Datei nach .env.local und trage echte Werte ein.

# Optional: Wenn gesetzt, wird Claude für die Lead-Zusammenfassung verwendet.
# Wenn nicht gesetzt, fällt /api/summarize automatisch auf eine Template-Zusammenfassung zurück.
# Hol dir einen Key unter https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: Modell-Override (Standard: claude-opus-4-6)
# ANTHROPIC_MODEL=claude-opus-4-6
