# Mandorino — Beispiel für lokale Umgebungsvariablen.
# Kopieren Sie diese Datei zu `.env.local` und tragen Sie Ihre Werte ein.
# Alle Variablen sind optional — die App läuft auch ohne (Template-Fallback,
# kein E-Mail-Versand, localStorage-Persistenz).

# ============================================================================
# Claude (KI-Zusammenfassung — strikt deskriptiv, keine rechtliche Bewertung)
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-6

# ============================================================================
# Öffentliche URL der Mandorino-Instanz — wird in Notification-Links benutzt
# ============================================================================
# MANDORINO_PUBLIC_URL=https://kanzlei-beispiel.mandorino.app

# ============================================================================
# E-Mail-Versand (SMTP) — Outlook / Gmail / eigener Mailserver
# ============================================================================
# Outlook  → smtp.office365.com:587 (SMTP_SECURE=false, STARTTLS)
# Gmail    → smtp.gmail.com:587 (App-Password, nicht das normale Passwort!)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=leads@kanzlei-beispiel.de
# SMTP_PASS=********
# SMTP_FROM="Kanzlei Beispiel <leads@kanzlei-beispiel.de>"

# ============================================================================
# Slack / Teams / generischer Webhook (in tenant.config.ts referenziert)
# ============================================================================
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXXXXXX
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
# GENERIC_WEBHOOK_URL=https://n8n.kanzlei.de/webhook/lead
# WEBHOOK_TOKEN=optional-shared-secret

# ============================================================================
# Supabase (Persistenz + Auth)
# ============================================================================
# Im Supabase-Projekt: Settings → API
#
# Server-Key (Service-Role, voller Zugriff — NIE im Client benutzen!):
# SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
#
# Browser-Keys für Supabase Auth (sicher exponierbar — RLS schützt die Daten):
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
#
# Hinweis: solange die NEXT_PUBLIC_-Vars FEHLEN, läuft Login im MVP-Modus
# (Klartext-Passwörter aus tenant.config.ts, localStorage-Session). Sobald
# beide gesetzt sind, schaltet authStore automatisch auf Supabase Auth um.
